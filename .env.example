# Neon PostgreSQL connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Better Auth server URL (must match your local/prod app URL).
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your-long-random-secret"

# Better Auth client base URL (used in browser calls).
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# APP_URL: The URL where this applet is hosted (used for absolute file URLs).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenRouter.ai API key and model selection.
OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
